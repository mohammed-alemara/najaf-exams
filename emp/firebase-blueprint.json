{
  "entities": {
    "Teacher": {
      "title": "Teacher",
      "description": "Information about a teacher in a government school.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the teacher."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the teacher."
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the teacher."
        },
        "subject": {
          "type": "string",
          "description": "The subject the teacher teaches (e.g., Math, Arabic)."
        },
        "school": {
          "type": "string",
          "description": "The name of the school."
        },
        "hireDate": {
          "type": "string",
          "format": "date",
          "description": "The date the teacher was hired."
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive"],
          "description": "The current employment status."
        },
        "uid": {
          "type": "string",
          "description": "The UID of the user who created this record."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the record was created."
        }
      },
      "required": ["name", "subject", "school", "uid"]
    }
  },
  "firestore": {
    "/teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Collection of teacher records."
    }
  }
}
